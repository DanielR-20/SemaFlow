{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "title": "users",
    "properties": {
        "_id": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{24}$"
        },
        "first_name": {
            "type": "string"
        },
        "last_name": {
            "type": "string"
        },
        "email": {
            "type": "string"
        },
        "password_hash": {
            "type": "string"
        },
        "reputation_score": {
            "type": "integer"
        },
        "is_active": {
            "type": "boolean"
        },
        "register_date": {
            "type": "string",
            "format": "date"
        },
        "reports": {
            "type": "array",
            "additionalItems": true,
            "items": [
                {
                    "type": "integer"
                },
                {
                    "type": "string"
                },
                {
                    "type": "string"
                },
                {
                    "type": "string",
                    "format": "date"
                }
            ]
        }
    },
    "additionalProperties": false
}